# Copy to .env.local and adjust for your development environment
#
# Site URL — used in @-moz-document matching rules below.
SITE_URL=https://econversetest.connectedcommunity.org/caileesandbox/
CMS_LOCAL_PREVIEW_NAME=cms-local-preview
SOURCE_CSS=main/styles.css
JS_LOCAL_PREVIEW_NAME=js-local-preview
SOURCE_JS=main/main.js
OUTPUT_DIR=preview

# Matching rules — enable one or more; if all false, defaults to url-prefix(site URL)
#
# MATCH_DOMAIN=true — domain
# @-moz-document domain("econversetest.connectedcommunity.org")
#
# MATCH_URL_PREFIX=true — url-prefix
# @-moz-document url-prefix("https://econversetest.connectedcommunity.org/caileesandbox/")
#
# MATCH_URL=true — url
# @-moz-document url("https://econversetest.connectedcommunity.org/caileesandbox/")
#
# MATCH_REGEXP=true — regexp
# @-moz-document regexp("^https://econversetest\\.connectedcommunity\\.org/caileesandbox/.*$")
# Set MATCH_REGEXP_PATTERN to override the pattern (defaults to site URL if unset)

MATCH_DOMAIN=false
MATCH_URL_PREFIX=true
MATCH_URL=false
MATCH_REGEXP=false
